{
  "manifest_version": 3,
  "name": "MailTracker",
  "description": "Gmail-only tracking image helper.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "MailTracker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://crm.d14.app/*",
    "https://track.d14.app/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "logo.png"
      ],
      "matches": [
        "https://mail.google.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
