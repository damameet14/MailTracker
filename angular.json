{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "mailTrackerExtensionPopup": {
      "projectType": "application",
      "root": "extension/angularPopup",
      "sourceRoot": "extension/angularPopup/src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/chrome-extension",
            "index": {
              "input": "extension/angularPopup/src/index.html",
              "output": "popup.html"
            },
            "main": "extension/angularPopup/src/main.ts",
            "polyfills": [],
            "tsConfig": "extension/angularPopup/tsconfig.app.json",
            "assets": [],
            "styles": [
              "extension/angularPopup/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": false
              },
              "outputHashing": "none",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true
            }
          }
        }
      }
    }
  }
}
