# Application
NEXT_PUBLIC_APP_URL=https://crm.d14.app
NODE_ENV=development
ALLOWED_OWNER_EMAIL=

# Firebase client
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-inbox-crm
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin
FIREBASE_PROJECT_ID=demo-inbox-crm
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Gmail OAuth
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_REDIRECT_URI=https://crm.d14.app/api/integrations/gmail/callback
GMAIL_TOKEN_ENCRYPTION_KEY=
GMAIL_PROVIDER=mock

# Tracking
TRACKING_HMAC_SECRET=replace-with-at-least-32-random-bytes
TRACKING_BASE_URL=https://track.d14.app
EVENT_RETENTION_DAYS=180

# Extension
EXTENSION_ALLOWED_ORIGIN=chrome-extension://replace-me
NEXT_PUBLIC_EXTENSION_ID=

# Optional development
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
